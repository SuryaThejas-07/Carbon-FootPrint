{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@carbonwise/shared": ["packages/shared/src"],
      "@carbonwise/shared/*": ["packages/shared/src/*"],
      "@carbonwise/database": ["packages/database/src"],
      "@carbonwise/database/*": ["packages/database/src/*"]
    }
  }
}
